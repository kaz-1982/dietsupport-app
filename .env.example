# DietSupport 同期サーバー(FastAPI)の環境変数サンプル。
# これをコピーして .env を作成し、本番では実値に置き換える。
#   cp .env.example .env
# .env は .gitignore 済み(コミットしない)。このサンプルだけをコミットする。

# 実行環境。"production" にすると安全側設定が有効になり、
# JWT 秘密鍵が未設定なら起動を拒否する。ローカル開発では未設定(=development)でよい。
DIETSUPPORT_ENV=development

# 署名トークン(JWT風)の秘密鍵。production では必須。
# 十分に長いランダム文字列にする。生成例:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
DIETSUPPORT_JWT_SECRET=change-me-to-a-long-random-secret

# CORS 許可オリジン(カンマ区切り)。本番ドメインを指定する。
# ローカルは既定で http://localhost:5173 を許可するため未設定でよい。
DIETSUPPORT_ALLOWED_ORIGINS=https://your-production-domain.example

# SQLite DB ファイルのパス。既定は dietsupport.db。
DIETSUPPORT_DB=dietsupport.db
